.project-grid {
  max-width: 900px;   
  margin: auto;   
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-rows: 150px;
  gap: 50px;
}


.project.big {
  grid-column: span 2;
  grid-row: span 2;
}


.project {
  position: relative;
  overflow: hidden;
  border-radius: 15px;
  display: block;
}


.project img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}


.overlay {
  position: absolute;
  bottom: 0;
  width: 100%;
  padding: 15px;
  background: rgba(0,0,0,0.6);
  color: #fff;
  transition: 0.3s;
}


.project:hover .overlay {
  background: rgba(0,0,0,0.8);
}

.project img {
  transition: 0.4s;
}

.project:hover img {
  transform: scale(1.1);
}
